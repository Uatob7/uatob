rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to authenticated users for all rides
    // (In production, you might want to restrict to rides owned by the user)
    match /Rides/{rideId} {
      allow read: if request.auth != null;
      allow create, write: if request.auth != null && request.auth.uid != null;
    }

    // Optional: Add rules for users collection if needed
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

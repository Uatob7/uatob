rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ─────────────────────────────────────────
    // ADMIN
    // ─────────────────────────────────────────
    match /Admin/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /Admin/{docId}/{subcollection=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /Admin/views/events/{eventId} {
      allow read:          if isSignedIn();
      allow create:        if isSignedIn();
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────
    // RIDES
    // ─────────────────────────────────────────
    match /Rides/{rideId} {
      allow read:   if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.uid ||
        request.auth.uid == resource.data.driverUid
      );
      allow delete: if false;
    }

    match /Rides/{rideId}/Messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.auth.uid == get(/databases/$(database)/documents/Rides/$(rideId)).data.uid ||
        request.auth.uid == get(/databases/$(database)/documents/Rides/$(rideId)).data.driverUid
      );
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────
    // DRIVERS
    // ─────────────────────────────────────────
    match /Drivers/{driverId} {
      allow read:  if true;
      allow write: if isOwner(driverId);
    }

    // ─────────────────────────────────────────
    // USERS / RIDERS
    // ─────────────────────────────────────────
    match /Riders/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /Accounts/{userId} {
      allow read:  if isSignedIn();
      allow write: if isOwner(userId);
    }

    // ─────────────────────────────────────────
    // SEARCH
    // ─────────────────────────────────────────
    match /Search/{searchId} {
      allow read:   if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == resource.data.uid;
      allow delete: if false;
    }

    // ─────────────────────────────────────────
    // REVIEWS
    // ─────────────────────────────────────────
    match /Reviews/{reviewId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == resource.data.uid;
      allow delete: if false;
    }

    // ─────────────────────────────────────────
    // SUPPORT
    // ─────────────────────────────────────────
    match /Support/{messageId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;
    }

    match /SupportThreads/{threadId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;
    }

    // ─────────────────────────────────────────
    // CONVERSATIONS
    // ─────────────────────────────────────────
    match /Conversations/{convId} {
      allow read, write: if isSignedIn();
    }

    match /Conversations/{convId}/Messages/{messageId} {
      allow read, write: if isSignedIn();
    }

    // ─────────────────────────────────────────
    // COUNTS
    // ─────────────────────────────────────────
    match /counts/{docId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // ─────────────────────────────────────────
    // FEED
    // ─────────────────────────────────────────
    match /Feed/{feedId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.auth.uid == request.resource.data.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.paymentStatus == 'pending';
      allow update: if isSignedIn()
                    && request.auth.uid == resource.data.uid
                    && request.resource.data.uid == resource.data.uid;
      allow delete: if false;
    }

    // ─────────────────────────────────────────
    // PROMO CODES
    // ─────────────────────────────────────────
    match /PromoCodes/{code} {
      allow read:  if isSignedIn();
      allow write: if false;
    }

    // ─────────────────────────────────────────
    // VIEWS
    // ─────────────────────────────────────────
    match /Views/{viewId} {
      allow read:          if false;
      allow create:        if true;
      allow update:        if true;
      allow delete:        if false;
    }

    // ─────────────────────────────────────────
    // DRIVER BALANCE LEDGER
    // ─────────────────────────────────────────
    match /DriverBalance/{driverId} {
      allow read:          if isOwner(driverId);
      allow write:         if isOwner(driverId);
    }

    // ─────────────────────────────────────────
    // DRIVER SETTLEMENTS
    // ─────────────────────────────────────────
    match /DriverSettlements/{settlementId} {
      allow read:          if isSignedIn() && resource.data.driverUid == request.auth.uid;
      allow create:        if isSignedIn() && request.resource.data.driverUid == request.auth.uid;
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────
    // SETTLEMENT LOGS
    // ─────────────────────────────────────────
    match /SettlementLogs/{logId} {
      allow read:          if isSignedIn() && resource.data.driverUid == request.auth.uid;
      allow create:        if isSignedIn() && request.resource.data.driverUid == request.auth.uid;
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────
    // DEFAULT DENY
    // ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔹 Rides collection
    match /Rides/{rideId} {
      // Any logged-in user can read available rides
      allow read: if request.auth != null;

      // Allow creating rides (riders)
      allow create: if request.auth != null;

      // Allow updates (e.g. driver accepts ride)
      allow update: if request.auth != null;

      // Optional: block deletes
      allow delete: if false;
    }

    // 🔹 Drivers collection
    match /Drivers/{driverId} {
      // Any logged-in user can read all drivers (for admin dashboard)
      allow read: if request.auth != null;

      // Driver can only write to their own document
      allow write: if request.auth != null && request.auth.uid == driverId;
    }

    // 🔹 Users collection
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 🔹 Accounts collection
    match /Accounts/{accountId} {
      // Any logged-in user can read all accounts
      allow read: if request.auth != null;

      // Allow updates for own account
      allow write: if request.auth != null && request.auth.uid == accountId;
    }

    // ❌ Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
